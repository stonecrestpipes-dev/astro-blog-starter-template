---
const siteTitle = "Stonecrest Pipes";
const siteDescription =
  "Stonecrest Pipes is being built as a home for collectors and enthusiasts.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <style>
      :root {
        /* Updated to match your business card */
        --bg: #d8c2a3;
        --bg-deep: #c4a882;
        --brand: #6b2e2e;
        --text: #3a2a22;
        --text-soft: #5a463b;
        --border: rgba(107, 46, 46, 0.25);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);

        background:
          radial-gradient(circle at top left, rgba(107,46,46,0.08), transparent 40%),
          radial-gradient(circle at bottom right, rgba(90,60,40,0.12), transparent 50%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-deep) 100%);
      }

      .hero {
        width: min(100%, 800px);
        margin: 0 auto;
        padding: 60px 24px;
        text-align: center;
      }

      .logo {
        width: 280px;
        max-width: 100%;
        margin-bottom: 30px;
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--brand);
        margin-bottom: 20px;
      }

      /* Reduced size */
      h1 {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        line-height: 1.2;
        margin: 0 0 20px 0;
        text-transform: uppercase;
      }

      .intro {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--text-soft);
        margin-bottom: 40px;
      }

      .signup {
        border-top: 1px solid var(--border);
        padding-top: 30px;
      }

      .pipe-icon {
        font-size: 1.6rem;
        margin-bottom: 10px;
        color: var(--brand);
      }

      .signup h2 {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 1.2rem;
        margin-bottom: 10px;
      }

      .signup-sub {
        font-size: 0.95rem;
        margin-bottom: 20px;
        color: var(--text-soft);
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 420px;
        margin: 0 auto;
      }

      input {
        padding: 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        font-size: 1rem;
      }

      button {
        padding: 14px;
        border-radius: 999px;
        border: none;
        background: var(--brand);
        color: white;
        font-weight: bold;
        letter-spacing: 0.08em;
        cursor: pointer;
      }

      .note {
        margin-top: 15px;
        font-size: 0.85rem;
        color: var(--text-soft);
      }

      .divider {
        margin-top: 30px;
        font-size: 1.4rem;
        color: var(--brand);
      }
    </style>
  </head>

  <body>
    <main class="hero">

      <img src="/logo.png" class="logo" alt="Stonecrest Pipes logo" />

      <div class="eyebrow">Coming Soon</div>

      <h1>Built Around the Craft of Pipe Smoking</h1>

      <p class="intro">
        Stonecrest Pipes is being built as a home for collectors,
        enthusiasts, and the wider world of tobacco pipes.
      </p>

      <div class="signup">

        <!-- Pipe-style icon -->
        <div class="pipe-icon">⎯◡⎯</div>

        <h2>Get Launch Updates</h2>

        <p class="signup-sub">
          Be the first to know when we go live.
        </p>

        <form
          action="https://YOUR_DC.list-manage.com/subscribe/post?u=YOUR_U&id=YOUR_ID"
          method="POST"
          target="_blank"
        >
          <input
            type="email"
            name="EMAIL"
            placeholder="Enter your email address"
            required
          />

          <!-- Mailchimp bot field -->
          <div style="position: absolute; left: -5000px;">
            <input type="text" name="b_YOUR_U_YOUR_ID" tabindex="-1" value="" />
          </div>

          <button type="submit">Subscribe</button>
        </form>

        <p class="note">
          No spam. Just updates on launch and new features.
        </p>

        <div class="divider">⎯◡⎯</div>

      </div>
    </main>
  </body>
</html>
