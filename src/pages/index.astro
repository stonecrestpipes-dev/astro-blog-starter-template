---
const siteTitle = "The Pipe Smokers App | Stonecrest Pipes";
const siteDescription =
  "A home for your briar and leaf. Tasting notes. Cellar inventory. Collection tracking. Everything you love about the pipe, finally organized.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <style>
      :root {
        --bg: #d8c2a3;
        --bg-deep: #c4a882;
        --brand: #6b2e2e;
        --text: #3a2a22;
        --text-soft: #5a463b;
        --border: rgba(107, 46, 46, 0.3);

        --space-sm: 12px;
        --space-md: 20px;
        --space-lg: 32px;
        --space-xl: 48px;
        --space-2xl: 72px;

        --button-text: #f3e7da;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(107, 46, 46, 0.08), transparent 40%),
          radial-gradient(circle at bottom right, rgba(90, 60, 40, 0.12), transparent 50%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-deep) 100%);
      }

      input:focus-visible,
      button:focus-visible {
        outline: 3px solid rgba(107, 46, 46, 0.45);
        outline-offset: 3px;
      }

      .hero {
        width: min(100%, 860px);
        margin: 0 auto;
        padding: clamp(24px, 5vh, 40px) 24px var(--space-2xl);
        text-align: center;
      }

      .logo {
        width: 280px;
        max-width: 100%;
        margin-bottom: var(--space-xl);
      }

      h1 {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        margin-bottom: var(--space-lg);
        text-transform: uppercase;
      }

      .intro {
        max-width: 760px;
        margin: 0 auto var(--space-xl);
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--text-soft);
      }

      .intro span {
        display: block;
        margin-top: var(--space-md);
      }

      .signup {
        border-top: 1px solid var(--border);
        padding-top: var(--space-xl);
      }

      .signup h2 {
        margin-bottom: var(--space-xl);
        font-size: 1.25rem;
        line-height: 1.4;
      }

      .form-row {
        display: flex;
        gap: var(--space-sm);
        max-width: 580px;
        margin: 0 auto;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }

      input {
        flex: 1;
        padding: 18px 20px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(216, 194, 163, 0.35);
      }

      button {
        width: 40%;
        min-width: 170px;
        padding: 18px;
        border-radius: 999px;
        border: none;
        background: var(--brand);
        color: var(--button-text);
        font-weight: bold;
        cursor: pointer;
      }

      .form-message {
        margin-top: var(--space-md);
      }

      @media (max-width: 640px) {
        .form-row {
          flex-direction: column;
        }

        button {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <main class="hero">
      <img src="/logo.png" class="logo" alt="Stonecrest Pipes" />

      <h1>Built Around the Craft of Pipe Smoking</h1>

      <p class="intro">
        <span>A home for your briar and leaf.</span>
        <span>Tasting notes. Cellar inventory. Collection tracking.</span>
        <span>Everything you love about the pipe, finally organized.</span>
        <span>Stonecrest Pipes. Coming soon.</span>
      </p>

      <section class="signup">
        <h2>
          Get your rotation ready. Be the first to know when the platform goes live.
        </h2>

        <form
          id="mailchimp-form"
          action="https://stonecrestpipes.us2.list-manage.com/subscribe/post?u=c3b9974aae8355c7864339251&id=1e529e9700&f_id=0043c2e1f0"
          method="POST"
        >
          <div class="form-row">
            <label class="visually-hidden" for="email">Email address</label>

            <input
              id="email"
              type="email"
              name="EMAIL"
              placeholder="Enter your email address"
              required
            />

            <button type="submit">Follow the Build</button>
          </div>

          <!-- Honeypot -->
          <div style="position:absolute; left:-5000px;">
            <input
              type="text"
              name="b_c3b9974aae8355c7864339251_1e529e9700"
              tabindex="-1"
              value=""
            />
          </div>

          <p id="form-message" class="form-message"></p>
        </form>
      </section>
    </main>
  </body>
</html>

