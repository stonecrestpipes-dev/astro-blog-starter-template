---
const siteTitle = "Stonecrest Pipes";
const siteDescription =
  "Stonecrest Pipes is being built as a home for collectors and enthusiasts.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <style>
      :root {
        --bg: #d8c2a3;
        --bg-deep: #c4a882;
        --brand: #6b2e2e;
        --text: #3a2a22;
        --text-soft: #5a463b;
        --border: rgba(107, 46, 46, 0.25);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(107, 46, 46, 0.08), transparent 40%),
          radial-gradient(circle at bottom right, rgba(90, 60, 40, 0.12), transparent 50%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-deep) 100%);
      }

      .hero {
        width: min(100%, 860px);
        margin: 0 auto;
        padding: 80px 24px;
        text-align: center;
      }

      .logo {
        width: 280px;
        max-width: 100%;
        margin-bottom: 40px;
      }

      h1 {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        line-height: 1.2;
        margin: 0 0 24px 0;
        text-transform: uppercase;
      }

      .intro {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--text-soft);
        margin-bottom: 40px;
      }

      .signup {
        border-top: 1px solid var(--border);
        padding-top: 30px;
      }

      .signup h2 {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 1.2rem;
        margin-bottom: 10px;
      }

      .signup-sub {
        font-size: 0.95rem;
        margin-bottom: 30px;
        color: var(--text-soft);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .form-row {
        display: flex;
        gap: 12px;
        max-width: 560px;
        margin: 0 auto;
      }

      input {
        flex: 1;
        padding: 18px 20px;
        border-radius: 999px;
        border: 1px solid var(--border);
        font-size: 1.05rem;
        background: transparent;
        color: var(--text);
      }

      input::placeholder {
        color: var(--text-soft);
      }

      button {
        width: 40%;
        min-width: 150px;
        padding: 18px 20px;
        border-radius: 999px;
        border: none;
        background: var(--brand);
        color: white;
        font-weight: bold;
        font-size: 1rem;
        letter-spacing: 0.08em;
        cursor: pointer;
      }

      button:disabled {
        opacity: 0.7;
        cursor: not-allowed;
      }

      .form-message {
        min-height: 24px;
        margin-top: 18px;
        font-size: 0.95rem;
        color: var(--text-soft);
      }

      .form-message.success {
        color: var(--brand);
        font-weight: bold;
      }

      .form-message.error {
        color: #7a1f1f;
      }

      @media (max-width: 640px) {
        .hero {
          padding: 60px 16px;
        }

        h1 {
          font-size: 1.8rem;
        }

        .form-row {
          flex-direction: column;
        }

        button {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <main class="hero">
      <img src="/logo.png" class="logo" alt="Stonecrest Pipes logo" />

      <h1>Built Around the Craft of Pipe Smoking</h1>

      <p class="intro">
        Stonecrest Pipes is being built as a home for collectors,
        enthusiasts, and the wider world of tobacco pipes.
      </p>

      <div class="signup">
        <h2>Be the first to know when we go live</h2>

        <p class="signup-sub">
          Get launch updates
        </p>

        <form
          id="mailchimp-form"
          action="https://YOUR_DC.list-manage.com/subscribe/post?u=YOUR_U&id=YOUR_ID"
          method="POST"
        >
          <div class="form-row">
            <input
              id="email"
              type="email"
              name="EMAIL"
              placeholder="Enter your email address"
              required
            />

            <button id="submit-button" type="submit">Subscribe</button>
          </div>

          <div style="position: absolute; left: -5000px;" aria-hidden="true">
            <input type="text" name="b_YOUR_U_YOUR_ID" tabindex="-1" value="" />
          </div>

          <p id="form-message" class="form-message"></p>
        </form>
      </div>
    </main>

    <script is:inline>
      const form = document.getElementById("mailchimp-form");
      const message = document.getElementById("form-message");
      const button = document.getElementById("submit-button");

      form.addEventListener("submit", function (event) {
        event.preventDefault();

        const formData = new FormData(form);
        const params = new URLSearchParams(formData);

        const callbackName = "mailchimpCallback_" + Date.now();

        const actionUrl = form.action.replace("/post?", "/post-json?");
        const script = document.createElement("script");

        message.textContent = "Submitting...";
        message.className = "form-message";
        button.disabled = true;

        window[callbackName] = function (response) {
          if (response.result === "success") {
            message.textContent = "Thank you — you're on the list.";
            message.className = "form-message success";
            form.reset();
          } else {
            message.textContent =
              response.msg || "Something went wrong. Please try again.";
            message.className = "form-message error";
          }

          button.disabled = false;
          delete window[callbackName];
          script.remove();
        };

        script.src =
          actionUrl +
          "&" +
          params.toString() +
          "&c=" +
          callbackName;

        document.body.appendChild(script);
      });
    </script>
  </body>
</html>
