---
const siteTitle = "The Pipe Smokers App | Stonecrest Pipes";
const siteDescription =
  "Track your pipe rotations, manage your cellar inventory, and refine your palate with detailed tasting logs.";
const siteUrl = "https://stonecrestpipes.com";
const socialImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={socialImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={socialImage} />

    <style>
      :root {
        --bg: #d8c2a3;
        --bg-deep: #c4a882;
        --brand: #6b2e2e;
        --text: #3a2a22;
        --text-soft: #5a463b;
        --border: rgba(107, 46, 46, 0.3);

        --space-sm: 12px;
        --space-md: 20px;
        --space-lg: 32px;
        --space-xl: 48px;
        --space-2xl: 72px;

        --button-text: #f3e7da;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(107, 46, 46, 0.08), transparent 40%),
          radial-gradient(circle at bottom right, rgba(90, 60, 40, 0.12), transparent 50%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-deep) 100%);
      }

      .hero {
        width: min(100%, 1120px);
        margin: 0 auto;
        padding: clamp(24px, 5vh, 40px) 24px var(--space-2xl);
      }

      .logo-wrap {
        text-align: center;
        margin-bottom: var(--space-lg);
      }

      .logo {
        width: 280px;
        max-width: 100%;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: var(--space-xl);
        align-items: center;
      }

      .content {
        text-align: left;
      }

      h1 {
        font-size: clamp(1.8rem, 2.5vw, 2.2rem);
        line-height: 1.2;
        margin-bottom: var(--space-lg);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .intro {
        max-width: 680px;
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--text-soft);
      }

      .signup {
        border-left: 1px solid var(--border);
        padding-left: var(--space-xl);
      }

      .signup h2 {
        margin-bottom: var(--space-xl);
        font-size: 1.25rem;
        line-height: 1.4;
      }

      .form-row {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
        max-width: 420px;
      }

      input {
        padding: 18px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(216, 194, 163, 0.35);
      }

      button {
        padding: 18px;
        border-radius: 999px;
        border: none;
        background: var(--brand);
        color: var(--button-text);
        font-weight: bold;
        cursor: pointer;
      }

      @media (max-width: 800px) {
        .hero-grid { display: block; }
        .content { text-align: center; }
        .signup {
          border-left: none;
          border-top: 1px solid var(--border);
          padding-left: 0;
          padding-top: var(--space-xl);
        }
      }
    </style>
  </head>

  <body>
    <main class="hero">
      <div class="logo-wrap">
        <img src="/logo.png" class="logo" alt="Stonecrest Pipes" />
      </div>

      <div class="hero-grid">
        <section class="content">
          <h1>Built Around the Craft of Pipe Smoking</h1>

          <p class="intro">
            Every Pipe. Every Blend. Every Note. Never forget a smoke again.
            Track your pipe rotations, manage your cellar inventory, and refine
            your palate with detailed tasting logs. The ultimate companion for
            the organized enthusiast.
          </p>
        </section>

        <section class="signup">
          <h2>
            Get your rotation ready. Be the first to know when the platform goes live.
          </h2>

          <form
            action="https://stonecrestpipes.us2.list-manage.com/subscribe/post?u=c3b9974aae8355c7864339251&id=1e529e9700&f_id=0043c2e1f0"
            method="POST"
          >
            <div class="form-row">
              <input
                type="email"
                name="EMAIL"
                placeholder="Enter your email address"
                required
              />

              <button type="submit">Follow the Build</button>
            </div>

            <div style="position:absolute; left:-5000px;">
              <input
                type="text"
                name="b_c3b9974aae8355c7864339251_1e529e9700"
                tabindex="-1"
                value=""
              />
            </div>
          </form>
        </section>
      </div>
    </main>
  </body>
</html>
