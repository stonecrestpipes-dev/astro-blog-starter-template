---
const siteTitle = "Stonecrest Pipes";
const siteDescription =
  "Stonecrest Pipes is being built to bring together pipes, blends, tasting notes, cellar tracking, and the wider pipe world.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <style>
      :root {
        --bg: #d8c2a3;
        --bg-deep: #c4a882;
        --brand: #6b2e2e;
        --text: #3a2a22;
        --text-soft: #5a463b;
        --border: rgba(107, 46, 46, 0.3);

        --space-sm: 12px;
        --space-md: 20px;
        --space-lg: 32px;
        --space-xl: 48px;
        --space-2xl: 72px;

        /* improved button text color */
        --button-text: #f3e7da;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(107, 46, 46, 0.08), transparent 40%),
          radial-gradient(circle at bottom right, rgba(90, 60, 40, 0.12), transparent 50%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-deep) 100%);
      }

      a,
      button,
      input {
        font: inherit;
      }

      input:focus-visible,
      button:focus-visible {
        outline: 3px solid rgba(107, 46, 46, 0.45);
        outline-offset: 3px;
      }

      .hero {
        width: min(100%, 860px);
        margin: 0 auto;
        padding: var(--space-2xl) 24px;
        text-align: center;
      }

      .logo {
        width: 280px;
        max-width: 100%;
        height: auto;
        margin-bottom: var(--space-xl);
      }

      h1 {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        line-height: 1.2;
        margin: 0 0 var(--space-lg);
        text-transform: uppercase;
      }

      .intro {
        max-width: 760px;
        margin: 0 auto var(--space-xl);
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--text-soft);
      }

      .intro span {
        display: block;
      }

      .intro span + span {
        margin-top: var(--space-md);
      }

      .signup {
        border-top: 1px solid var(--border);
        padding-top: var(--space-xl);
      }

      .signup h2 {
        margin: 0 0 var(--space-sm);
        font-size: 1.25rem;
        line-height: 1.3;
        letter-spacing: 0.04em;
      }

      .signup-sub {
        margin: 0 0 var(--space-xl);
        font-size: 1rem;
        color: var(--text-soft);
      }

      .form-row {
        display: flex;
        gap: var(--space-sm);
        max-width: 580px;
        margin: 0 auto;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      input[type="email"] {
        flex: 1;
        min-width: 0;
        padding: 18px 20px;
        border-radius: 999px;
        border: 1px solid var(--border);
        font-size: 1.05rem;
        background: rgba(216, 194, 163, 0.35);
        color: var(--text);
      }

      input[type="email"]::placeholder {
        color: var(--text-soft);
        opacity: 0.85;
      }

      button {
        width: 40%;
        min-width: 150px;
        padding: 18px 20px;
        border-radius: 999px;
        border: none;
        background: var(--brand);
        color: var(--button-text);
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: transform 0.15s ease, filter 0.15s ease;
      }

      button:hover {
        transform: translateY(-1px);
        filter: brightness(1.05);
      }

      button:disabled {
        opacity: 0.7;
        cursor: not-allowed;
      }

      .form-message {
        min-height: 24px;
        margin: var(--space-md) 0 0;
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--text-soft);
      }

      .form-message.success {
        color: var(--brand);
        font-weight: 700;
      }

      .form-message.error {
        color: #7a1f1f;
        font-weight: 700;
      }

      @media (max-width: 640px) {
        .hero {
          padding: var(--space-xl) 16px;
        }

        .logo {
          width: 240px;
          margin-bottom: var(--space-lg);
        }

        h1 {
          font-size: 1.75rem;
        }

        .form-row {
          flex-direction: column;
        }

        button {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <main class="hero">
      <img src="/logo.png" class="logo" alt="Stonecrest Pipes" />

      <h1>Built Around the Craft of Pipe Smoking</h1>

      <p class="intro">
        <span>Do you know when your pipes were last smoked—or with what?</span>
        <span>Trying to keep track of tasting notes, blends, and what’s actually in your cellar?</span>
        <span>If your pipe world is spread across different sites, notes, and memory…</span>
        <span>Stonecrest Pipes is being built to bring it all together.</span>
      </p>

      <section class="signup" aria-labelledby="signup-heading">
        <h2 id="signup-heading">Be the first to know when we go live</h2>

        <p class="signup-sub">
          Get Launch Updates
        </p>

        <form
          id="mailchimp-form"
          action="https://YOUR_DC.list-manage.com/subscribe/post?u=YOUR_U&id=YOUR_ID"
          method="POST"
        >
          <div class="form-row">
            <label class="visually-hidden" for="email">Email address</label>

            <input
              id="email"
              type="email"
              name="EMAIL"
              placeholder="Enter your email address"
              autocomplete="email"
              required
            />

            <button id="submit-button" type="submit">Subscribe</button>
          </div>

          <div style="position: absolute; left: -5000px;" aria-hidden="true">
            <input type="text" name="b_YOUR_U_YOUR_ID" tabindex="-1" value="" />
          </div>

          <p
            id="form-message"
            class="form-message"
            role="status"
            aria-live="polite"
          ></p>
        </form>
      </section>
    </main>

    <script is:inline>
      const form = document.getElementById("mailchimp-form");
      const message = document.getElementById("form-message");
      const button = document.getElementById("submit-button");

      form.addEventListener("submit", function (event) {
        event.preventDefault();

        const formData = new FormData(form);
        const params = new URLSearchParams(formData);

        const callbackName = "mailchimpCallback_" + Date.now();
        const actionUrl = form.action.replace("/post?", "/post-json?");
        const script = document.createElement("script");

        message.textContent = "Submitting...";
        message.className = "form-message";
        button.disabled = true;

        window[callbackName] = function (response) {
          if (response.result === "success") {
            message.textContent = "Thank you — you're on the list.";
            message.className = "form-message success";
            form.reset();
          } else {
            message.textContent =
              response.msg || "Something went wrong. Please try again.";
            message.className = "form-message error";
          }

          button.disabled = false;
          delete window[callbackName];
          script.remove();
        };

        script.src =
          actionUrl +
          "&" +
          params.toString() +
          "&c=" +
          callbackName;

        document.body.appendChild(script);
      });
    </script>
  </body>
</html>
